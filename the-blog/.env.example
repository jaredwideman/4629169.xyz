# --- Auth ---
# Comma-separated list of email addresses allowed to log in.
ALLOWED_EMAILS=you@example.com

# 32+ char random secret for signing JWT session cookies.
# Generate with: openssl rand -base64 48
SESSION_SECRET=replace-me-with-a-long-random-string

# Public URL the magic link should point to (no trailing slash).
PUBLIC_URL=https://4629169.xyz

# --- Email (Resend) ---
RESEND_API_KEY=re_xxx
# A verified sender. For quick start use onboarding@resend.dev.
MAIL_FROM=onboarding@resend.dev

# --- Content storage ---
# Path to the working git checkout containing posts/. The app reads + writes posts here.
# On the Windows server this is C:\apps\blog-content
BLOG_CONTENT_DIR=../

# --- Git push (only required on the server) ---
# Fine-grained PAT scoped to this repo with contents:write.
BLOG_GIT_PAT=
GIT_AUTHOR_NAME=Blog Bot
GIT_AUTHOR_EMAIL=blog-bot@4629169.xyz
GIT_REMOTE=origin
GIT_BRANCH=main

# --- Uploads ---
# Filesystem path where uploaded media is stored (served at <basePath>/uploads/...).
# Defaults to <app>/public/uploads.
UPLOADS_DIR=
